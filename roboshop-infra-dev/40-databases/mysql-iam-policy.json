{
    "Sid": "SSMRead",
    "Effect": "Allow",
    "Action": ["ssm:GetParameter", "ssm:DescribeParameters"],
    "Resource": "arn:aws:ssm:us-east-1:370400270361:parameter/roboshop/*",
    "Condition": {
        "StringEquals": {
            "aws:ResourceTag/environment": "${aws:PrincipalTag/environment}"
        }
    }
}
