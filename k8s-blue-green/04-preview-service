# for headless  we have attached this service to deployment and we have not given cluster ip to this service so that we can access the pod directly using dns name of the pod.
apiVersion: v1
kind: Service
metadata: 
  name: nginx-preview
spec:  
  type: LoadBalancer
  selector:
  # labels are used as selectors.so service add the pod which is having these labels.
    tier: frontend
    component: frontend
    version: green 
  ports:
  - protocol: TCP
    port: 80 # service port
    targetPort: 80 # container port  