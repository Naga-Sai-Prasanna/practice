//3.post-build

pipeline {
    agent {
        node {
            label 'ROBOSHOP'
        }
    }
    stages {
        stage('Build') {
            steps {
                script {
                    sh """
                       echo "Building"
                    """   
                }
                
            }
        }
        stage('Test') {
            steps {
                script {
                    sh """
                       echo "Testing"
                    """   
                
            }
        }
        stage('Deploy') {
            steps {
               script {
                    sh """
                       echo "Deploying"
                    """   
                
            }
        }
    }
    // post build
    post {
        always {
            echo 'i will always say Hello again!'
        }
    }
}